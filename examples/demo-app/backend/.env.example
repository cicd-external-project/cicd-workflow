# flowci-demo-backend — environment variables
#
# This app has no database, no auth, and no external service calls, so
# there's intentionally very little here. Copy this file to `.env` only if
# you want to override the default port for local development; the app
# runs fine with zero environment variables set.

# Port the NestJS app listens on. Defaults to 3000 if unset (see src/main.ts).
# Render injects its own PORT value in production — do not hardcode one in
# render.yaml or the Dockerfile.
PORT=3000

# Standard Node environment flag. The Dockerfile sets this to "production"
# in the runtime stage; leave unset or "development" for local runs.
NODE_ENV=development
